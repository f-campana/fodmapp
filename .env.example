# FODMAPP platform shared environment template
#
# Rules:
# 1) Keep shared infra variables at repo root.
# 2) Keep app-specific runtime variables in per-app .env.local files (when apps exist).
# 3) Do not commit real credentials.

# ------------------------------
# Current API runtime (active)
# ------------------------------
API_DB_URL=postgresql://postgres:postgres@localhost:5432/fodmap_test
API_NAME=fodmapp-api
API_VERSION=v0

# -----------------------------------------
# Current Phase2 replay script (active)
# etl/phase2/scripts/phase2_replay_from_zero.sh
# -----------------------------------------
ROOT_DIR=
REPLAY_DB=fodmap_replay_test
REPLAY_DB_URL=postgresql://postgres@localhost:5432/fodmap_replay_test
ADMIN_DB=template1
ADMIN_DB_URL=postgresql://postgres@localhost:5432/template1
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PSQL_BIN=psql

# CIQUAL file overrides (optional)
CIQUAL_DATA_DIR=
CIQUAL_XLSX=
CIQUAL_ALIM_XML=
CIQUAL_GRP_XML=

# -----------------------------------------
# Current Phase3 seed script (active)
# etl/phase3/scripts/phase3_seed_for_api_ci.sh
# -----------------------------------------
SEED_DB_URL=postgresql://postgres:postgres@localhost:5432/fodmap_test

# -----------------------------------------
# Storybook deploy workflow (CI secret contract)
# .github/workflows/storybook-deploy.yml
# -----------------------------------------
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# -----------------------------------------
# App runtime integrations (env-gated; optional)
# apps/app
# -----------------------------------------
# Sentry runtime bootstrap (disabled when both keys are empty)
SENTRY_DSN_APP=
NEXT_PUBLIC_SENTRY_DSN_APP=

# Clerk runtime bootstrap (disabled when any key is missing)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Plausible runtime script (disabled when domain is empty)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Axeptio integration is intentionally deferred/no-op in current scaffold.
# These keys are reserved for the future runtime activation milestone.
NEXT_PUBLIC_AXEPTIO_CLIENT_ID=
NEXT_PUBLIC_AXEPTIO_COOKIES_VERSION=

# Temporary manual consent override for non-production validation only.
# Runtime guard ignores `true` in production until consent runtime is activated.
NEXT_PUBLIC_ANALYTICS_CONSENT_GRANTED=false

# Public API base URL for app reads and consent-backed API access.
# Use the API origin; app clients normalize `/v0` automatically.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Local preview auth for /espace and /espace/suivi validation only.
# Development-only fallback when Clerk runtime auth is not configured.
APP_AUTH_PREVIEW_USER_ID=

# Marketing app waitlist backend
MARKETING_DB_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Marketing feature flags
NEXT_PUBLIC_FF_SECTION_APPROACH=0
NEXT_PUBLIC_FF_SECTION_TRUST=0

# -----------------------------------------
# Reserved near-term placeholders (not wired yet)
# -----------------------------------------
# Neon / database branching
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_BRANCH_PROD=main
NEON_BRANCH_STAGING=staging
NEON_DATABASE_URL_PROD=
NEON_DATABASE_URL_STAGING=

# Monitoring
SENTRY_DSN_API=

# FODMAP platform shared environment template
#
# Rules:
# 1) Keep shared infra variables at repo root.
# 2) Keep app-specific runtime variables in per-app .env.local files (when apps exist).
# 3) Do not commit real credentials.

# ------------------------------
# Current API runtime (active)
# ------------------------------
API_DB_URL=postgresql://postgres:postgres@localhost:5432/fodmap_test
API_NAME=fodmap-api
API_VERSION=v0
BARCODE_FEATURE_ENABLED=false
BARCODE_INTERNAL_ENABLED=false
BARCODE_ADMIN_TOKEN=
OFF_API_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=FODMAPPlatform/0.1 (contact@example.com)
OFF_TIMEOUT_SECONDS=3
BARCODE_CACHE_TTL_HOURS=168
BARCODE_HEURISTIC_THRESHOLD=0.75
BARCODE_HEURISTIC_MARGIN=0.10

# -----------------------------------------
# Current Phase2 replay script (active)
# etl/phase2/scripts/phase2_replay_from_zero.sh
# -----------------------------------------
ROOT_DIR=
REPLAY_DB=fodmap_replay_test
REPLAY_DB_URL=postgresql://postgres@localhost:5432/fodmap_replay_test
ADMIN_DB=template1
ADMIN_DB_URL=postgresql://postgres@localhost:5432/template1
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PSQL_BIN=psql

# CIQUAL file overrides (optional)
CIQUAL_DATA_DIR=
CIQUAL_XLSX=
CIQUAL_ALIM_XML=
CIQUAL_GRP_XML=

# -----------------------------------------
# Current Phase3 seed script (active)
# etl/phase3/scripts/phase3_seed_for_api_ci.sh
# -----------------------------------------
SEED_DB_URL=postgresql://postgres:postgres@localhost:5432/fodmap_test

# -----------------------------------------
# Reserved near-term placeholders (not wired yet)
# -----------------------------------------
# Neon / database branching
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_BRANCH_PROD=main
NEON_BRANCH_STAGING=staging
NEON_DATABASE_URL_PROD=
NEON_DATABASE_URL_STAGING=

# Monitoring
SENTRY_DSN_API=
SENTRY_DSN_APP=

# Auth (future Next.js app)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

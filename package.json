{
  "name": "fodmap-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "hook:install": "git config core.hooksPath .githooks",
    "build": "pnpm exec turbo run build",
    "lint": "pnpm format:check && pnpm lint:js",
    "lint:js": "pnpm exec eslint .",
    "lint:js:ci": "pnpm exec eslint . --max-warnings=0",
    "lint:ci": "pnpm format:check && pnpm lint:js:ci",
    "lint:llm": "pnpm exec eslint --config eslint.llm.config.mjs apps/app apps/storybook packages/ui",
    "lint:llm:ci": "pnpm exec eslint --config eslint.llm.config.mjs --max-warnings=0 apps/app apps/storybook packages/ui",
    "python:lint:api": "cd api && uv sync --extra lint --locked && uv run --project api ruff check . && uv run --project api ruff format --check .",
    "python:lint:reporting": "cd etl/phase2/reporting && uv sync --extra lint --locked && uv run --project etl/phase2/reporting ruff check . && uv run --project etl/phase2/reporting ruff format --check .",
    "python:lint": "pnpm python:lint:api && pnpm python:lint:reporting",
    "python:ci": "pnpm python:lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm exec turbo run test --filter=@fodmapp/ui --filter=@fodmapp/app",
    "test:storybook": "pnpm --filter @fodmapp/storybook storybook:test",
    "prepare": "pnpm hook:install",
    "typecheck": "pnpm exec turbo run typecheck --only --filter=@fodmapp/content-config --filter=@fodmapp/types --filter=@fodmapp/ui --filter=@fodmapp/reporting --filter=@fodmapp/storybook --filter=@fodmapp/app --filter=@fodmapp/marketing --filter=@fodmapp/research",
    "tokens:generate": "pnpm --filter @fodmapp/design-tokens tokens:generate",
    "tokens:check": "pnpm exec turbo run tokens:check --filter=@fodmapp/design-tokens",
    "tailwind:styles:check": "pnpm exec turbo run styles:check --filter=@fodmapp/tailwind-config",
    "openapi:generate": "pnpm --filter @fodmapp/types openapi:generate",
    "openapi:check": "pnpm exec turbo run openapi:check --filter=@fodmapp/types",
    "ui:build": "pnpm exec turbo run build --filter=@fodmapp/ui",
    "ui:styles:check": "pnpm exec turbo run styles:check --filter=@fodmapp/ui",
    "ui:typecheck": "pnpm exec turbo run typecheck --filter=@fodmapp/ui",
    "ui:test": "pnpm exec turbo run test --filter=@fodmapp/ui",
    "app:dev": "pnpm --filter @fodmapp/app dev",
    "app:build": "pnpm exec turbo run build --filter=@fodmapp/app",
    "app:analyze": "pnpm --filter @fodmapp/app analyze && node ./scripts/collect-next-analyze.mjs",
    "app:typecheck": "pnpm exec turbo run typecheck --filter=@fodmapp/app",
    "app:test": "pnpm exec turbo run test --filter=@fodmapp/app",
    "marketing:build": "pnpm exec turbo run build --filter=@fodmapp/marketing",
    "marketing:typecheck": "pnpm exec turbo run typecheck --filter=@fodmapp/marketing",
    "research:build": "pnpm exec turbo run build --filter=@fodmapp/research",
    "research:typecheck": "pnpm exec turbo run typecheck --filter=@fodmapp/research",
    "reporting:typecheck": "pnpm exec turbo run typecheck --filter=@fodmapp/reporting",
    "reporting:test": "pnpm exec turbo run test --filter=@fodmapp/reporting",
    "storybook": "pnpm exec turbo run storybook --filter=@fodmapp/storybook",
    "storybook:build": "pnpm exec turbo run storybook:build --filter=@fodmapp/storybook",
    "storybook:analyze": "pnpm --filter @fodmapp/storybook storybook:analyze",
    "storybook:test": "pnpm --filter @fodmapp/storybook storybook:test",
    "bundle:report:static": "pnpm --filter @fodmapp/marketing build && pnpm --filter @fodmapp/research build && node ./scripts/report-static-assets.mjs",
    "check:all": "./.github/scripts/quality-gate.sh && pnpm lint:ci && pnpm python:ci && pnpm openapi:check && pnpm tokens:check && pnpm tailwind:styles:check && pnpm ui:build && pnpm ui:styles:check && pnpm ui:typecheck && pnpm ui:test && pnpm exec turbo run typecheck --filter=@fodmapp/storybook && pnpm storybook:build && pnpm storybook:test && pnpm app:test && pnpm app:typecheck && pnpm app:build && pnpm marketing:typecheck && pnpm marketing:build && pnpm research:typecheck && pnpm research:build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:scope:test": "node --test .github/scripts/detect-ci-scope.test.mjs",
    "changeset:ci:test": "node --test .github/scripts/check-pr-changesets.test.mjs",
    "changeset:ci:status": "node .github/scripts/check-pr-changesets.mjs",
    "changeset:ci:lint:all": "node .github/scripts/check-pr-changesets.mjs --all",
    "changeset:ci:status:strict": "BASE_SHA=origin/main HEAD_SHA=HEAD node .github/scripts/check-pr-changesets.mjs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.29.8",
    "@eslint/js": "9.39.3",
    "@fodmapp/eslint-config": "workspace:*",
    "@next/eslint-plugin-next": "16.1.6",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "3.8.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "17.3.0",
    "metro-runtime": "0.84.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.1",
    "turbo": "2.8.16",
    "typescript-eslint": "8.56.1"
  }
}

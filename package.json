{
  "name": "fodmap-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "tokens:generate": "pnpm --filter @fodmap/design-tokens tokens:generate",
    "tokens:check": "pnpm --filter @fodmap/design-tokens tokens:check",
    "openapi:generate": "pnpm --filter @fodmap/types openapi:generate",
    "openapi:check": "pnpm --filter @fodmap/types openapi:check",
    "ui:build": "pnpm --filter @fodmap/ui build",
    "ui:typecheck": "pnpm --filter @fodmap/ui typecheck",
    "ui:test": "pnpm --filter @fodmap/ui test",
    "storybook": "pnpm --filter @fodmap/storybook storybook",
    "storybook:build": "pnpm --filter @fodmap/storybook storybook:build",
    "storybook:test": "pnpm --filter @fodmap/storybook storybook:test",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.0",
    "turbo": "2.8.10"
  }
}

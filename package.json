{
  "name": "fodmap-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test --filter=@fodmap/ui --filter=@fodmap/app",
    "test:storybook": "pnpm --filter @fodmap/storybook test",
    "typecheck": "turbo run typecheck --filter=@fodmap/content-config --filter=@fodmap/types --filter=@fodmap/ui --filter=@fodmap/storybook --filter=@fodmap/app --filter=@fodmap/marketing --filter=@fodmap/research",
    "tokens:generate": "pnpm --filter @fodmap/design-tokens tokens:generate",
    "tokens:check": "turbo run tokens:check --filter=@fodmap/design-tokens",
    "tailwind:styles:check": "turbo run styles:check --filter=@fodmap/tailwind-config",
    "openapi:generate": "pnpm --filter @fodmap/types openapi:generate",
    "openapi:check": "turbo run openapi:check --filter=@fodmap/types",
    "ui:build": "turbo run build --filter=@fodmap/ui",
    "ui:styles:check": "turbo run styles:check --filter=@fodmap/ui",
    "ui:typecheck": "turbo run typecheck --filter=@fodmap/ui",
    "ui:test": "turbo run test --filter=@fodmap/ui",
    "app:dev": "pnpm --filter @fodmap/app dev",
    "app:build": "turbo run build --filter=@fodmap/app",
    "app:typecheck": "turbo run typecheck --filter=@fodmap/app",
    "app:test": "turbo run test --filter=@fodmap/app",
    "marketing:build": "turbo run build --filter=@fodmap/marketing",
    "marketing:typecheck": "turbo run typecheck --filter=@fodmap/marketing",
    "research:build": "turbo run build --filter=@fodmap/research",
    "research:typecheck": "turbo run typecheck --filter=@fodmap/research",
    "storybook": "turbo run storybook --filter=@fodmap/storybook",
    "storybook:build": "turbo run storybook:build --filter=@fodmap/storybook",
    "storybook:test": "turbo run storybook:test --filter=@fodmap/storybook",
    "check:all": "./.github/scripts/quality-gate.sh && pnpm openapi:check && pnpm tokens:check && pnpm tailwind:styles:check && pnpm ui:build && pnpm ui:styles:check && pnpm ui:typecheck && pnpm ui:test && turbo run typecheck --filter=@fodmap/storybook && pnpm storybook:build && pnpm storybook:test && pnpm app:test && pnpm app:typecheck && pnpm app:build && pnpm marketing:typecheck && pnpm marketing:build && pnpm research:typecheck && pnpm research:build",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.0",
    "turbo": "2.8.10"
  }
}

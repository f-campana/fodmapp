{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "storybook": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["apps/storybook/storybook-static/**"]
    },
    "storybook:test": {
      "dependsOn": ["storybook:build"],
      "outputs": []
    }
  }
}

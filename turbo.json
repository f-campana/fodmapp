{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "storybook-static/**",
        "src/generated/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "outputs": []
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "storybook:test": {
      "dependsOn": ["storybook:build"],
      "cache": false,
      "outputs": []
    },
    "openapi:check": {
      "cache": false,
      "outputs": []
    },
    "tokens:check": {
      "outputs": []
    },
    "styles:check": {
      "outputs": []
    }
  }
}

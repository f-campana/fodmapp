{
  "name": "@fodmap/ui",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@fodmap/tailwind-config": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && pnpm run build:ts && pnpm run build:styles",
    "build:ts": "tsup",
    "build:styles": "tailwindcss --config ./tailwind.config.ts -i ./src/styles/index.css -o ./dist/styles.css --minify",
    "styles:check": "node ./scripts/check-styles-contract.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest-axe": "3.5.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jest-axe": "10.0.0",
    "jsdom": "28.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}

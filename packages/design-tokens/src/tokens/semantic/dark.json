{
  "semantic": {
    "color": {
      "background": {
        "canvas": {
          "$value": "{base.color.brand.canvasDark}",
          "$type": "color"
        }
      },
      "surface": {
        "default": {
          "$value": "{base.color.brand.surfaceDark}",
          "$type": "color"
        },
        "raised": {
          "$value": "{base.color.brand.surfaceStrongDark}",
          "$type": "color"
        },
        "muted": {
          "$value": "{base.color.brand.surfaceMutedDark}",
          "$type": "color"
        },
        "inverse": { "$value": "{base.color.neutral.50}", "$type": "color" }
      },
      "text": {
        "primary": {
          "$value": "{base.color.brand.textDark}",
          "$type": "color"
        },
        "muted": {
          "$value": "{base.color.brand.textMutedDark}",
          "$type": "color"
        },
        "inverse": { "$value": "{base.color.neutral.950}", "$type": "color" }
      },
      "border": {
        "default": {
          "$value": "{base.color.brand.borderDark}",
          "$type": "color"
        },
        "control": { "$value": "{base.color.neutral.500}", "$type": "color" },
        "subtle": { "$value": "{base.color.neutral.700}", "$type": "color" },
        "strong": { "$value": "{base.color.neutral.500}", "$type": "color" }
      },
      "focus": {
        "ring": { "$value": "{base.color.brand.ringDark}", "$type": "color" },
        "ringAccessible": {
          "$value": "{base.color.brand.accentDark}",
          "$type": "color"
        },
        "ringSoft": {
          "$value": "{base.color.brand.ringSoftDark}",
          "$type": "color"
        }
      },
      "validation": {
        "error": {
          "border": {
            "$value": "{base.color.brand.dangerValidationBorderDark}",
            "$type": "color"
          },
          "ring": {
            "$value": "{base.color.brand.dangerDark}",
            "$type": "color"
          },
          "ringSoft": {
            "$value": "{base.color.brand.dangerValidationRingDark}",
            "$type": "color"
          },
          "text": {
            "$value": "{base.color.brand.dangerDark}",
            "$type": "color"
          }
        }
      },
      "action": {
        "primary": {
          "bg": { "$value": "{base.color.brand.accentDark}", "$type": "color" },
          "bgHover": {
            "$value": "{base.color.brand.accentStrongDark}",
            "$type": "color"
          },
          "fg": {
            "$value": "{base.color.brand.accentForegroundDark}",
            "$type": "color"
          }
        },
        "secondary": {
          "bg": { "$value": "{base.color.neutral.700}", "$type": "color" },
          "bgHover": { "$value": "{base.color.neutral.600}", "$type": "color" },
          "fg": { "$value": "{base.color.neutral.50}", "$type": "color" }
        },
        "outline": {
          "bg": {
            "$value": "{base.color.brand.controlSubtleDark}",
            "$type": "color"
          },
          "bgHover": {
            "$value": "{base.color.brand.controlSubtleStrongDark}",
            "$type": "color"
          },
          "border": { "$value": "{base.color.neutral.500}", "$type": "color" },
          "fg": { "$value": "{base.color.brand.textDark}", "$type": "color" }
        },
        "ghost": {
          "bgHover": {
            "$value": "{base.color.brand.surfaceMutedSoftDark}",
            "$type": "color"
          },
          "fg": { "$value": "{base.color.brand.textDark}", "$type": "color" }
        },
        "destructive": {
          "bg": { "$value": "{base.color.brand.dangerDark}", "$type": "color" },
          "bgHover": {
            "$value": "{base.color.brand.dangerStrongDark}",
            "$type": "color"
          },
          "fg": {
            "$value": "{base.color.brand.dangerForegroundDark}",
            "$type": "color"
          },
          "bgSubtle": {
            "$value": "{base.color.brand.dangerSubtleDark}",
            "$type": "color"
          },
          "bgSubtleHover": {
            "$value": "{base.color.brand.dangerSubtleStrongDark}",
            "$type": "color"
          },
          "fgSubtle": {
            "$value": "{base.color.brand.dangerSubtleFgDark}",
            "$type": "color"
          },
          "borderSubtle": {
            "$value": "{base.color.brand.dangerSubtleBorderDark}",
            "$type": "color"
          },
          "ringSubtle": {
            "$value": "{base.color.brand.dangerSubtleBorderDark}",
            "$type": "color"
          }
        }
      },
      "status": {
        "info": {
          "bg": { "$value": "{base.color.blue.400}", "$type": "color" },
          "fg": { "$value": "{base.color.neutral.950}", "$type": "color" }
        },
        "success": {
          "bg": { "$value": "{base.color.emerald.400}", "$type": "color" },
          "fg": { "$value": "{base.color.neutral.950}", "$type": "color" },
          "bgSubtle": { "$value": "{base.color.emerald.900}", "$type": "color" }
        },
        "warning": {
          "bg": {
            "$value": "{base.color.brand.warningDark}",
            "$type": "color"
          },
          "fg": {
            "$value": "{base.color.brand.warningForegroundDark}",
            "$type": "color"
          }
        },
        "danger": {
          "bg": { "$value": "{base.color.brand.dangerDark}", "$type": "color" },
          "fg": {
            "$value": "{base.color.brand.dangerForegroundDark}",
            "$type": "color"
          },
          "bgSubtle": {
            "$value": "{base.color.brand.dangerSubtleDark}",
            "$type": "color"
          }
        }
      },
      "data": {
        "axis": {
          "$value": "{base.color.brand.textMutedDark}",
          "$type": "color"
        },
        "grid": { "$value": "{base.color.neutral.700}", "$type": "color" },
        "track": { "$value": "{base.color.neutral.700}", "$type": "color" }
      }
    },
    "typography": {
      "font": {
        "family": {
          "body": {
            "$value": "{base.typography.fontFamily.body}",
            "$type": "fontFamily"
          },
          "display": {
            "$value": "{base.typography.fontFamily.display}",
            "$type": "fontFamily"
          }
        }
      }
    },
    "radius": {
      "control": { "$value": "{base.radius.lg}", "$type": "dimension" },
      "container": { "$value": "{base.radius.xl}", "$type": "dimension" },
      "pill": { "$value": "{base.radius.full}", "$type": "dimension" }
    },
    "space": {
      "controlX": { "$value": "{base.space.4}", "$type": "dimension" },
      "controlY": { "$value": "{base.space.2_5}", "$type": "dimension" },
      "section": { "$value": "{base.space.10}", "$type": "dimension" }
    },
    "motion": {
      "interactiveDuration": {
        "$value": "{base.motion.duration.fast}",
        "$type": "duration"
      },
      "interactiveEasing": {
        "$value": "{base.motion.easing.standard}",
        "$type": "cubicBezier"
      }
    }
  }
}

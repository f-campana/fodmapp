{
  "name": "@fodmap/reporting",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/reporting-theme.css"
  },
  "files": [
    "src",
    "dist",
    "src/styles/reporting-theme.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "colors:check": "if rg -n -- '#[0-9a-fA-F]{3,6}' src/scientific/render-scientific.ts; then echo 'Hex literals are not allowed in scientific renderer'; exit 1; fi",
    "test": "pnpm run colors:check && vitest run --passWithNoTests",
    "render:scientific": "tsx src/cli/render-scientific.ts",
    "render:dashboard": "tsx src/cli/render-dashboard.ts",
    "render:compare": "tsx src/cli/compare-render-baseline.ts"
  },
  "dependencies": {
    "@fodmap/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "tsup": "8.5.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}

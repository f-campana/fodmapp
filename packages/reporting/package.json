{
  "name": "@fodmapp/reporting",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard.d.ts",
      "import": "./dist/dashboard.js"
    },
    "./scientific": {
      "types": "./dist/scientific.d.ts",
      "import": "./dist/scientific.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsup && cp src/styles/reporting-theme.css dist/styles.css",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "colors:check": "if rg -n -- '#[0-9a-fA-F]{3,6}' src/scientific/render-scientific.ts; then echo 'Hex literals are not allowed in scientific renderer'; exit 1; fi",
    "test": "pnpm run colors:check && vitest run --passWithNoTests",
    "render:scientific": "tsx src/cli/render-scientific.ts",
    "render:dashboard": "tsx src/cli/render-dashboard.ts",
    "render:compare": "tsx src/cli/compare-render-baseline.ts"
  },
  "dependencies": {
    "@fodmapp/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.0.18"
  }
}

{
  "name": "@fodmapp/tailwind-config",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "exports": {
    "./foundation.css": "./foundation.css",
    "./shared-styles.css": "./shared-styles.css"
  },
  "files": [
    "foundation.css",
    "shared-styles.css",
    "README.md"
  ],
  "scripts": {
    "styles:generate": "node ./scripts/generate-shared-styles.mjs && pnpm prettier --write shared-styles.css",
    "styles:check": "pnpm run styles:generate && git diff --exit-code -- shared-styles.css"
  },
  "dependencies": {
    "@fodmapp/design-tokens": "workspace:*"
  },
  "peerDependencies": {
    "tailwindcss": "^4.2.0"
  }
}

{
  "name": "@fodmapp/mobile-prototype",
  "version": "0.3.4",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:shared": "pnpm --filter @fodmapp/domain build && pnpm --filter @fodmapp/api-client build",
    "start": "pnpm run build:shared && expo start",
    "ios": "pnpm run build:shared && expo start --ios",
    "typecheck": "pnpm run build:shared && tsc --noEmit",
    "test": "pnpm run build:shared && node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@fodmapp/api-client": "workspace:*",
    "@fodmapp/domain": "workspace:*",
    "@fodmapp/design-tokens": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~55.0.11",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.84.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.10",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}

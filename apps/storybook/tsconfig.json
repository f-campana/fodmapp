{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["react", "react-dom"]
  },
  "include": [".storybook/**/*.ts", ".storybook/**/*.d.ts", "stories/**/*.ts", "stories/**/*.tsx"]
}

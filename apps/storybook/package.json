{
  "name": "@fodmapp/storybook",
  "private": true,
  "version": "0.1.27",
  "type": "module",
  "scripts": {
    "build": "pnpm run storybook:build",
    "styles:build": "node ./scripts/build-preview-styles.mjs",
    "styles:watch": "node ./scripts/build-preview-styles.mjs --watch",
    "typecheck": "pnpm run storybook:typecheck",
    "test": "pnpm run test:local",
    "test:local": "pnpm run storybook:build && pnpm run storybook:test",
    "test:ci": "pnpm run storybook:test",
    "storybook": "node ./scripts/storybook-dev.mjs",
    "storybook:build": "pnpm run styles:build && storybook build",
    "storybook:analyze": "STORYBOOK_ANALYZE=true pnpm run storybook:build && node ./scripts/write-visualizer-report.mjs",
    "storybook:typecheck": "tsc -p tsconfig.json --noEmit && pnpm run stories:taxonomy:check",
    "storybook:serve": "http-server ./storybook-static -p 6006 -a 127.0.0.1 -c-1 --silent",
    "storybook:test": "start-server-and-test \"pnpm storybook:serve\" http://127.0.0.1:6006 \"test-storybook --url http://127.0.0.1:6006 --maxWorkers=2\"",
    "stories:taxonomy:check": "node ./scripts/check-component-taxonomy.mjs",
    "storybook:dev": "storybook dev -p 6006 --ci"
  },
  "dependencies": {
    "@fodmapp/design-tokens": "workspace:*",
    "@fodmapp/reporting": "workspace:*",
    "@fodmapp/ui": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@storybook/test-runner": "0.24.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "agentation": "2.2.1",
    "http-server": "14.1.1",
    "lucide-react": "^0.577.0",
    "playwright": "1.58.2",
    "rollup-plugin-visualizer": "7.0.1",
    "start-server-and-test": "2.1.5",
    "storybook": "10.3.3",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  }
}

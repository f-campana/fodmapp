---
import { getLocalizedCopy } from "@fodmapp/content-config/i18n";
import BaseLayout from "../layouts/BaseLayout.astro";

const copy = getLocalizedCopy("marketing", "fr");
---

<BaseLayout title={copy.title} description={copy.description}>
  <header>
    <p>{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p>{copy.description}</p>
  </header>
  <section>
    <ul>
      {copy.bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>
  </section>
</BaseLayout>

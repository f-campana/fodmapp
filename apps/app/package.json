{
  "name": "@fodmap/app",
  "private": true,
  "version": "0.1.26",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @fodmap/ui build && next dev",
    "build": "pnpm --filter @fodmap/ui build && next build",
    "analyze": "pnpm --filter @fodmap/ui build && ANALYZE=true next build --webpack",
    "start": "next start",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/nextjs": "6.39.0",
    "@fodmap/types": "workspace:*",
    "@fodmap/ui": "workspace:*",
    "@sentry/nextjs": "10.43.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.1.6",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}

{
  "name": "@fodmap/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @fodmap/ui build && next dev",
    "build": "pnpm --filter @fodmap/ui build && next build",
    "start": "next start",
    "typecheck": "pnpm --filter @fodmap/ui build && next typegen && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @fodmap/ui build && vitest run"
  },
  "dependencies": {
    "@fodmap/types": "workspace:*",
    "@fodmap/ui": "workspace:*",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}

---
import type { Locale } from "@fodmapp/content-config/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: Locale;
}

const { title, description, locale = "fr" } = Astro.props;
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main class="fd-research-shell">
      <slot />
    </main>
  </body>
</html>

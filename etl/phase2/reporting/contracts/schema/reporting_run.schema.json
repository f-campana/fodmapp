{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "phase2_reporting_run",
  "type": "object",
  "required": [
    "run_id",
    "schema_version",
    "generated_at_utc",
    "git_sha",
    "source_db_ref",
    "contract_version",
    "figures"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "schema_version": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "git_sha": {
      "type": "string",
      "minLength": 7
    },
    "source_db_ref": {
      "type": "string"
    },
    "source_db_meta": {
      "type": "object",
      "required": [
        "kind",
        "host",
        "database",
        "redacted"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "fixture",
            "db"
          ]
        },
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "database": {
          "type": [
            "string",
            "null"
          ]
        },
        "redacted": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "contract_version": {
      "type": "string"
    },
    "trigger": {
      "type": "string",
      "enum": ["pr_smoke", "main_full", "manual_full", "manual_baseline_update"]
    },
    "source_file_hashes": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "string"
        }
      }
    },
    "figures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./figure_payloads.schema.json"
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "now_set_ok": {
          "type": "boolean"
        },
        "now_set_fail_count": {
          "type": "integer",
          "minimum": 0
        },
        "now_set_warn_count": {
          "type": "integer",
          "minimum": 0
        },
        "snapshot_drift_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["out_path", "sha256"],
      "properties": {
        "out_path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "phase2_render_baseline_manifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "source_run",
    "contract_refs",
    "scientific",
    "public"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "phase2-render-baseline-manifest-v1"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_run": {
      "type": "object",
      "required": ["run_id", "git_sha", "source_db_ref", "contract_version"],
      "properties": {
        "run_id": { "type": "string" },
        "git_sha": { "type": "string" },
        "source_db_ref": { "type": "string" },
        "contract_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "scientific": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["figure_id", "file", "title", "sha256"],
        "properties": {
          "figure_id": {
            "type": "string",
            "enum": [
              "P-01_stage_progression_contract_curve",
              "P-02_candidate_pool_split_by_stage",
              "P-03_gap_completion_matrix",
              "Q-02_critical_contract_scorecard",
              "Q-03_snapshot_lock_drift_panel",
              "Q-04_rank2_exclusion_audit",
              "E-03_threshold_provenance_completeness",
              "E-04_rank2_quarantine_case_study"
            ]
          },
          "file": {
            "type": "string",
            "enum": [
              "fig_A_pipeline_progression.svg",
              "fig_B_candidate_pool_evolution.svg",
              "fig_C_gap_completion_heatmap.svg",
              "fig_D_status_distribution.svg",
              "fig_E_evidence_quality.svg",
              "fig_F_serving_load_vs_thresholds.svg",
              "fig_G_source_provenance.svg",
              "fig_H_quarantine_impact.svg"
            ]
          },
          "title": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "public": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "file", "title", "sha256"],
        "properties": {
          "artifact_id": { "type": "string", "const": "phase2_dashboard_html" },
          "file": { "type": "string", "const": "phase2_dashboard.html" },
          "title": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
